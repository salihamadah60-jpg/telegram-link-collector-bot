# Telegram API credentials — get from https://my.telegram.org/apps
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_PHONE=          # your phone number with country code, e.g. +1234567890

# Telegram BOT token — create a bot via @BotFather and paste the token here
BOT_TOKEN=

# Session file names (stored locally — keep them safe)
SESSION_NAME=userbot_session
BOT_SESSION_NAME=control_bot_session

# MongoDB connection string
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=telegram_bot

# OPTIONAL — global fallback target chat for .docx file delivery.
# Each user can set their own personal target via the bot UI (📍 Set Target button).
# If a user has set their own target, this value is ignored for them.
# Defaults to "me" (Saved Messages) if not set.
TARGET_CHAT_ID=me

# How many links to collect before sending the .docx file
LINKS_PER_FILE=100

# How many months of history to read when starting
HISTORY_MONTHS=3

# Chats to SKIP (blacklist) — comma-separated usernames or numeric IDs
# The bot automatically monitors ALL groups/channels you are in.
# Add any chats here that you do NOT want monitored.
# Example: EXCLUDED_CHATS=@somechannel,-1001234567890,@anothergroup
EXCLUDED_CHATS=
